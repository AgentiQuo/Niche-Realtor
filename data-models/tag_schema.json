{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tag",
  "type": "object",
  "properties": {
    "tag_id": { "type": "string" },
    "name": { "type": "string" },
    "polarity": { "type": "string", "enum": ["positive", "neutral", "negative"] },
    "relevance": { "type": "number", "minimum": 0, "maximum": 10 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "embedding": { "type": "array", "items": { "type": "number" } },
    "source": { "type": "string", "enum": ["image", "text", "neighborhood"] }
  },
  "required": ["tag_id", "name", "polarity", "relevance", "confidence", "source"]
}
