{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neighborhood",
  "type": "object",
  "properties": {
    "neighborhood_id": { "type": "string" },
    "name": { "type": "string" },
    "region": { "type": "string" },
    "tags": { "type": "array", "items": { "$ref": "tag_schema.json#" } },
    "embedding": { "type": "array", "items": { "type": "number" } },
    "similar_neighborhoods": { "type": "array", "items": { "type": "string" } },
    "vibe_summary": { "type": "string" },
    "match_score": { "type": "number" }
  },
  "required": ["neighborhood_id", "name", "region"]
}
